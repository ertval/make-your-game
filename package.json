{
  "name": "make-your-game",
  "version": "0.1.0",
  "license": "GPL-3.0",
  "private": false,
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration --passWithNoTests",
    "test:e2e": "playwright test tests/e2e/*.spec.js --pass-with-no-tests",
    "test:audit": "npm run test:audit:vitest && npm run test:audit:e2e",
    "test:audit:vitest": "vitest run tests/e2e/audit/*.test.js",
    "test:audit:e2e": "playwright test tests/e2e/audit/*.spec.js --pass-with-no-tests",
    "test:coverage": "vitest run --coverage",
    "coverage": "npm run test:coverage",
    "ci": "npm run lint && npm run test && npm run test:coverage && npm run validate:schema && npm run sbom",
    "validate:schema": "node scripts/validate-schema.mjs",
    "policy": "node scripts/policy-gate/run-all.mjs --mode=local --scope=all",
    "policy:repo": "node scripts/policy-gate/run-all.mjs --mode=local --scope=repo",
    "policy:quality": "node scripts/policy-gate/run-project-gate.mjs",
    "policy:checks": "node scripts/policy-gate/run-checks.mjs --check-set=pr --require-branch-ticket=true",
    "policy:checks:local": "npm run policy:prep && npm run policy:checks",
    "policy:trace": "node scripts/policy-gate/run-checks.mjs --check-set=repo",
    "policy:forbidden": "node scripts/policy-gate/check-forbidden.mjs --scope=changed",
    "policy:forbiddenrepo": "node scripts/policy-gate/check-forbidden.mjs --scope=repo",
    "policy:header": "node scripts/policy-gate/check-source-headers.mjs --scope=changed --mode=fail",
    "policy:headerrepo": "node scripts/policy-gate/check-source-headers.mjs --scope=repo --mode=fail",
    "policy:approve": "node scripts/policy-gate/require-approval.mjs",
    "policy:prep": "node scripts/policy-gate/prepare-context.mjs",
    "sbom": "npm sbom --sbom-format spdx --package-lock-only --omit=optional > sbom.json"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@playwright/test": "^1.59.1",
    "@vitest/coverage-v8": "^4.1.2",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "maxrects-packer": "^2.7.3",
    "sharp": "^0.34.5",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
