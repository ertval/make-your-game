{
  "name": "make-your-game",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:forbidden": "node scripts/policy-gate/check-forbidden.mjs --scope=repo",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test --pass-with-no-tests",
    "test:audit": "vitest run tests/e2e/audit",
    "test:coverage": "vitest run --coverage",
    "coverage": "npm run test:coverage",
    "validate:schema": "node scripts/validate-schema.mjs",
    "policy:prepare": "node scripts/policy-gate/prepare-context.mjs",
    "policy:checks": "node scripts/policy-gate/run-checks.mjs",
    "policy:approval": "node scripts/policy-gate/require-approval.mjs",
    "policy:headers": "node scripts/policy-gate/check-source-headers.mjs --scope=repo --mode=warn",
    "policy:project": "node scripts/policy-gate/run-project-gate.mjs",
    "policy:pr": "node scripts/policy-gate/run-all.mjs --mode=local --scope=pr --allow-missing-pr-body=false",
    "policy:repo": "node scripts/policy-gate/run-all.mjs --mode=local --scope=repo",
    "policy:local": "npm run policy:pr --",
    "ci:policy": "node scripts/policy-gate/run-all.mjs --mode=ci --scope=all",
    "ci:quality": "npm run policy:project",
    "policy:ci": "npm run ci:policy && npm run ci:quality",
    "pr:gate": "npm run policy:local --",
    "sbom": "npm ls --all --json > sbom.json",
    "ci": "npm run policy:ci"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.54.0",
    "@vitest/coverage-v8": "^3.2.4",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
