{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ms-ghostman.local/schemas/visual-manifest.schema.json",
  "title": "Visual Asset Manifest",
  "type": "object",
  "required": ["version", "assets"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+$"
    },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "path",
          "kind",
          "format",
          "width",
          "height",
          "tags",
          "critical"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "path": {
            "type": "string",
            "pattern": "^(assets/)?generated/(sprites|ui|tiles|effects)/[a-z0-9][a-z0-9-]*\\.(svg|png|webp)$"
          },
          "kind": {
            "type": "string",
            "enum": ["sprite", "ui", "tile", "effect"]
          },
          "format": {
            "type": "string",
            "enum": ["svg", "png", "webp"]
          },
          "width": {
            "type": "integer",
            "minimum": 1
          },
          "height": {
            "type": "integer",
            "minimum": 1
          },
          "critical": {
            "type": "boolean"
          },
          "tags": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
            }
          },
          "maxBytes": {
            "type": "integer",
            "minimum": 1
          },
          "notes": {
            "type": "string",
            "maxLength": 500
          }
        }
      }
    }
  }
}
