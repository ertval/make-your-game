{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ms-ghostman.local/schemas/audio-manifest.schema.json",
  "title": "Audio Asset Manifest",
  "type": "object",
  "required": ["version", "assets"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+$"
    },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "path", "category", "format", "durationMs", "critical", "loop"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "path": {
            "type": "string",
            "pattern": "^(assets/)?generated/(sfx|music|ui|ambience)/[a-z0-9][a-z0-9-]*\\.(mp3|m4a|ogg)$"
          },
          "category": {
            "type": "string",
            "enum": ["ui", "sfx", "music", "ambience"]
          },
          "format": {
            "type": "string",
            "enum": ["mp3", "m4a", "ogg"]
          },
          "durationMs": {
            "type": "integer",
            "minimum": 1
          },
          "loop": {
            "type": "boolean"
          },
          "critical": {
            "type": "boolean"
          },
          "channels": {
            "type": "integer",
            "minimum": 1,
            "maximum": 2
          },
          "sampleRateHz": {
            "type": "integer",
            "enum": [22050, 32000, 44100, 48000]
          },
          "loudnessLufs": {
            "type": "number",
            "minimum": -40,
            "maximum": 0
          },
          "maxBytes": {
            "type": "integer",
            "minimum": 1
          },
          "notes": {
            "type": "string",
            "maxLength": 500
          }
        }
      }
    }
  }
}
